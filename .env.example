# Google Calendar sync for the booking page (see README for setup steps).
# Calendar ID: Elizabeth's Gmail address (her primary calendar's ID is her email).
VITE_GOOGLE_CALENDAR_ID=nombre@gmail.com

# API key from Google Cloud Console, restricted to the Calendar API and to this site's domain.
VITE_GOOGLE_CALENDAR_API_KEY=

# The calendar must be shared as "Make available to public" with
# "See only free/busy (hide details)" so the site can read busy times
# without exposing patient names or appointment details.
